<Window x:Class="CosmosManager.Views.FormEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CosmosManager.Converters"
        xmlns:vm="clr-namespace:CosmosManager.ViewModels"
        Title="Edit Item" Height="780" Width="1150"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=vm:FormEditorViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Window.Resources>
        <conv:KindToVisibilityConverter x:Key="KindToVis"/>
        <conv:StringToImageSourceConverter x:Key="StrToImg"/>
        <conv:NullOrEmptyToVisibilityConverter x:Key="StrToVis"/>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="0,8,0,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
        </Style>
        <Style x:Key="LangBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <!-- DataTemplates for the Other-fields generic editor. Selected at runtime by DynamicFieldTemplateSelector. -->
        <DataTemplate x:Key="DynStringTemplate">
            <StackPanel Margin="0,4,0,4">
                <Label Content="{Binding Name}"/>
                <TextBox Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="DynNumberTemplate">
            <StackPanel Margin="0,4,0,4">
                <Label Content="{Binding Name, StringFormat='{}{0} (number)'}"/>
                <TextBox Text="{Binding StringValue, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="DynBoolTemplate">
            <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                <CheckBox IsChecked="{Binding BoolValue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="DynLocalizedTemplate">
            <StackPanel Margin="0,4,0,4">
                <Label Content="{Binding Name, StringFormat='{}{0} (localized)'}"/>
                <Label Content="English" Margin="12,2,0,0" FontWeight="Normal" FontSize="11"/>
                <TextBox Style="{StaticResource LangBoxStyle}" Height="50" Text="{Binding LocalizedEn, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Spanish" Margin="12,2,0,0" FontWeight="Normal" FontSize="11"/>
                <TextBox Style="{StaticResource LangBoxStyle}" Height="50" Text="{Binding LocalizedEs, UpdateSourceTrigger=PropertyChanged}"/>
                <Label Content="Portuguese" Margin="12,2,0,0" FontWeight="Normal" FontSize="11"/>
                <TextBox Style="{StaticResource LangBoxStyle}" Height="50" Text="{Binding LocalizedPt, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="DynReadOnlyTemplate">
            <StackPanel Margin="0,4,0,4">
                <Label Content="{Binding Name}"/>
                <TextBlock Text="{Binding ReadOnlyDescription}" Foreground="Gray" FontStyle="Italic" Margin="4,0,0,0"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Form -->
        <ScrollViewer Grid.Row="0" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="20,15">
            <StackPanel>

                <TextBlock Text="{Binding Kind, StringFormat='{}{0} editor'}"
                           FontSize="20" FontWeight="Light" Margin="0,0,0,12"/>

                <Label Content="ID"/>
                <TextBox Text="{Binding Id, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- ───── Movies / Series ───── -->
                <StackPanel Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter='Movie,Series'}">
                    <Label Content="IMDb title id (e.g. tt0111161)"/>
                    <TextBox Text="{Binding TitleId, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Category (partition key)"/>
                    <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="My rating (0–10)"/>
                            <TextBox Text="{Binding MyRating, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <Label Content="Order"/>
                            <TextBox Text="{Binding Order, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="Review (English)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Height="70"
                             Text="{Binding ReviewEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Review (Spanish)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Height="70"
                             Text="{Binding ReviewEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Review (Portuguese)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Height="70"
                             Text="{Binding ReviewPt, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <!-- ───── Gaming ───── -->
                <StackPanel Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter='Gaming'}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Platform (partition key)"/>
                            <TextBox Text="{Binding Platform, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <Label Content="Section"/>
                            <TextBox Text="{Binding Section, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="Title (English)"/>
                    <TextBox Text="{Binding TitleEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Title (Spanish — optional)"/>
                    <TextBox Text="{Binding TitleEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Title (Portuguese — optional)"/>
                    <TextBox Text="{Binding TitlePt, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Status"/>
                            <ComboBox SelectedValue="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Content" IsEditable="True">
                                <ComboBoxItem Content="completed"/>
                                <ComboBoxItem Content="playing"/>
                                <ComboBoxItem Content="backlog"/>
                                <ComboBoxItem Content="dropped"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,8,0">
                            <Label Content="Type"/>
                            <ComboBox SelectedValue="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Content" IsEditable="True">
                                <ComboBoxItem Content="card"/>
                                <ComboBoxItem Content="group"/>
                            </ComboBox>
                        </StackPanel>
                        <CheckBox Grid.Column="2" Content="Co-Op" IsChecked="{Binding CoOp}" VerticalAlignment="Bottom" Margin="8,0,8,8"/>
                        <CheckBox Grid.Column="3" Content="Online" IsChecked="{Binding Online}" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                    </Grid>

                    <Label Content="Image URL (blob storage or external)"/>
                    <TextBox Text="{Binding ImageUrl, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Link URL (store / page)"/>
                    <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Description (English)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding DescriptionEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Description (Spanish — optional)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding DescriptionEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Description (Portuguese — optional)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding DescriptionPt, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Recommendation (English)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding RecommendationEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Recommendation (Spanish — optional)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding RecommendationEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Recommendation (Portuguese — optional)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding RecommendationPt, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Order"/>
                    <TextBox Text="{Binding Order, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>

                    <TextBlock Margin="0,12,0,0" FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap"
                               Text="{Binding GamingChildCount, StringFormat='Group entries (games[]): {0} — edit via raw JSON if needed.'}"
                               Visibility="{Binding GamingChildCount, Converter={StaticResource StrToVis}}"/>
                </StackPanel>

                <!-- ───── Monthly Update ───── -->
                <StackPanel Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter='MonthlyUpdate'}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Month (YYYY-MM, partition key)"/>
                            <TextBox Text="{Binding Month, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <Label Content="Category"/>
                            <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="Title (English)"/>
                    <TextBox Text="{Binding TitleEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Title (Spanish — optional)"/>
                    <TextBox Text="{Binding TitleEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Title (Portuguese — optional)"/>
                    <TextBox Text="{Binding TitlePt, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Release date"/>
                    <TextBox Text="{Binding ReleaseDate, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Platforms (comma-separated)"/>
                    <TextBox Text="{Binding Platforms, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Description (English)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding DescriptionEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Description (Spanish — optional)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding DescriptionEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Description (Portuguese — optional)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding DescriptionPt, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="YouTube video ID"/>
                    <TextBox Text="{Binding YoutubeVideoId, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="YouTube title (English)"/>
                    <TextBox Text="{Binding YoutubeTitleEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="YouTube title (Spanish — optional)"/>
                    <TextBox Text="{Binding YoutubeTitleEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="YouTube title (Portuguese — optional)"/>
                    <TextBox Text="{Binding YoutubeTitlePt, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Image URL"/>
                    <TextBox Text="{Binding ImageUrl, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Order"/>
                    <TextBox Text="{Binding Order, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                </StackPanel>

                <!-- ───── Park ───── -->
                <StackPanel Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter='Park'}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Provider (partition key)"/>
                            <TextBox Text="{Binding Provider, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <Label Content="Park ID"/>
                            <TextBox Text="{Binding ParkId, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="Name (English)"/>
                    <TextBox Text="{Binding NameEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Name (Spanish)"/>
                    <TextBox Text="{Binding NameEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Name (Portuguese)"/>
                    <TextBox Text="{Binding NamePt, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Description (English)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding ParkDescriptionEn, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Description (Spanish)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding ParkDescriptionEs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Label Content="Description (Portuguese)"/>
                    <TextBox Style="{StaticResource LangBoxStyle}" Text="{Binding ParkDescriptionPt, UpdateSourceTrigger=PropertyChanged}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Map center (lat,lng)"/>
                            <TextBox Text="{Binding MapCenter, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <Label Content="Map zoom"/>
                            <TextBox Text="{Binding MapZoom, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"/>
                        </StackPanel>
                    </Grid>

                    <Label Content="Image URL (optional hero image)"/>
                    <TextBox Text="{Binding ParkImageUrl, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Items (read-only summary)"/>
                    <Border BorderBrush="#CCC" BorderThickness="1" Padding="4" MaxHeight="200">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ParkItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" Margin="2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <TextBlock FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"
                               Text="Per-item editing (attractions, restaurants, etc.) requires the raw JSON editor below. Item data is preserved when saving."/>
                </StackPanel>

                <!-- ───── Other fields (generic editor for anything the typed form doesn't expose) ───── -->
                <Expander Header="Other fields" Margin="0,16,0,0"
                          IsExpanded="False"
                          Visibility="{Binding DynamicFields.Count, Converter={StaticResource StrToVis}}">
                    <ItemsControl ItemsSource="{Binding DynamicFields}">
                        <ItemsControl.ItemTemplateSelector>
                            <vm:DynamicFieldTemplateSelector
                                StringTemplate="{StaticResource DynStringTemplate}"
                                NumberTemplate="{StaticResource DynNumberTemplate}"
                                BoolTemplate="{StaticResource DynBoolTemplate}"
                                LocalizedTemplate="{StaticResource DynLocalizedTemplate}"
                                ReadOnlyTemplate="{StaticResource DynReadOnlyTemplate}"/>
                        </ItemsControl.ItemTemplateSelector>
                    </ItemsControl>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- Preview pane -->
        <Border Grid.Row="0" Grid.Column="1" Background="#F7F7F7" BorderBrush="#DDD" BorderThickness="1,0,0,0" Padding="14">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Preview" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>

                    <!-- Image -->
                    <Border BorderBrush="#CCC" BorderThickness="1" Background="White"
                            Visibility="{Binding ImagePreviewUrl, Converter={StaticResource StrToVis}}"
                            Margin="0,0,0,10" Padding="6">
                        <Image Source="{Binding ImagePreviewUrl, Converter={StaticResource StrToImg}}"
                               Stretch="Uniform" MaxHeight="240"/>
                    </Border>

                    <!-- YouTube thumbnail -->
                    <Border BorderBrush="#CCC" BorderThickness="1" Background="Black"
                            Visibility="{Binding YoutubeThumbnailUrl, Converter={StaticResource StrToVis}}"
                            Margin="0,0,0,6" Padding="0">
                        <Grid>
                            <Image Source="{Binding YoutubeThumbnailUrl, Converter={StaticResource StrToImg}}"
                                   Stretch="Uniform" MaxHeight="200"/>
                            <TextBlock Text="▶" FontSize="48" Foreground="#CCFF0000"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Button Content="Open YouTube video"
                            Visibility="{Binding YoutubeWatchUrl, Converter={StaticResource StrToVis}}"
                            Click="OpenYoutube_Click" Margin="0,0,0,10" Padding="8,4"/>

                    <!-- IMDb -->
                    <Button Content="Open on IMDb"
                            Visibility="{Binding ImdbUrl, Converter={StaticResource StrToVis}}"
                            Click="OpenImdb_Click" Margin="0,0,0,10" Padding="8,4"/>

                    <!-- Map -->
                    <Button Content="Open map (OpenStreetMap)"
                            Visibility="{Binding MapPreviewUrl, Converter={StaticResource StrToVis}}"
                            Click="OpenMap_Click" Margin="0,0,0,10" Padding="8,4"/>

                    <!-- Link URL -->
                    <Button Content="Open external link"
                            Visibility="{Binding Url, Converter={StaticResource StrToVis}}"
                            Click="OpenUrl_Click" Margin="0,0,0,10" Padding="8,4"/>

                    <TextBlock Text="Empty fields are hidden from the preview. Image previews load asynchronously."
                               TextWrapping="Wrap" FontStyle="Italic" Foreground="Gray" FontSize="11" Margin="0,10,0,0"/>

                    <Separator Margin="0,12,0,8"/>
                    <TextBlock Text="Sample document from this container" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <Button Content="Fetch sample document" Command="{Binding FetchSampleCommand}"
                            HorizontalAlignment="Left" Padding="8,4" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding SampleDocumentJson, Mode=OneWay}"
                             Visibility="{Binding SampleDocumentJson, Converter={StaticResource StrToVis}}"
                             IsReadOnly="True" FontFamily="Consolas" FontSize="11"
                             AcceptsReturn="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             MaxHeight="260"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#F0F0F0" BorderBrush="#CCC" BorderThickness="0,1,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Edit raw JSON…" Click="EditJson_Click" Padding="12,6" MinWidth="120" Margin="0,0,8,0"/>
                <Button Content="Cancel" IsCancel="True" Padding="12,6" MinWidth="80" Margin="0,0,8,0"/>
                <Button Content="Save" IsDefault="True" Click="Save_Click" Padding="12,6" MinWidth="80" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
